# ---------------------------------------------------------------------------
# .gitignore for dotllm (.NET + GGUF model artifacts)
# ---------------------------------------------------------------------------

# ---- Build output ---------------------------------------------------------
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]uild/
[Pp]ublished/
[Pp]ublish/
artifacts/

# ---- .NET restore / build intermediates -----------------------------------
project.lock.json
project.fragment.lock.json
*.nuget.props
*.nuget.targets
*.binlog
*.tlog
*.pdb
*.mdb
*.ilk
*.meta
*.opendb
*.VC.db
*.VC.VC.opendb

# ---- NuGet ----------------------------------------------------------------
*.nupkg
*.snupkg
.nuget/
packages/
!src/**/packages/build/
!tools/packages/
# Allow NuGet config when it's a project artifact
!nuget.config

# ---- Test results ---------------------------------------------------------
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml
coverage/
coverage*.json
coverage*.xml
coverage*.info
lcov.info
*.opencover.xml
TestResults/
BenchmarkDotNet.Artifacts/

# ---- Rider / ReSharper ----------------------------------------------------
.idea/
*.sln.iml
*.DotSettings.user
_ReSharper*/
*.[Rr]e[Ss]harper
*.ncrunchproject
*.ncrunchsolution
_NCrunch_*

# ---- Visual Studio --------------------------------------------------------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.sln.iml
*.VisualState.xml
*.vspscc
*.vssscc
*.pidb
*.svclog
*.psess
*.vsp
*.vspx
*.sap
*.e2e
$tf/
_Pvt_Extensions/
.mfractor/
ipch/
*.aps
*.ncb
*.cachefile
*.log
*.tmp
*.tmp_proj
*_wpftmp.csproj

# ---- VS Code --------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/
.ionide/

# ---- macOS ----------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.fseventsd
.TemporaryItems
.DocumentRevisions-V100

# ---- Windows --------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
*.lnk

# ---- Linux ----------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ---- Secrets and local config ---------------------------------------------
*.pfx
*.snk
*.key
*.pem
*.p12
*.crt
secrets.json
appsettings.*.local.json
appsettings.Development.json
.env
.env.*
!.env.example
user-secrets/

# ---- LLM / GGUF model artifacts (do NOT commit binary weights) ------------
*.gguf
*.ggml
*.bin
*.safetensors
*.onnx
*.pt
*.pth
*.ckpt
*.h5
*.msgpack
models/
model-cache/
.cache/
hf-cache/
huggingface/

# Allow small fixture models used in tests (explicit opt-in)
!tests/**/fixtures/**/*.gguf
!tests/**/fixtures/**/*.bin

# ---- Tokenizer / dataset caches -------------------------------------------
tokenizer-cache/
datasets/
*.arrow
*.parquet

# ---- Native backend build artifacts ---------------------------------------
*.so
*.dylib
*.dll
*.lib
*.a
*.exp
*.obj
*.o
*.pdb
# Allow dotnet-managed DLLs under bin/ — they're already ignored above.

# ---- Vulkan / Metal / CUDA shader build caches ----------------------------
*.spv
*.metallib
*.cubin
*.fatbin
*.ptx
shader-cache/

# ---- BenchmarkDotNet ------------------------------------------------------
BenchmarkDotNet.Artifacts/
**/BenchmarkDotNet.Artifacts/

# ---- Docs build -----------------------------------------------------------
_site/
docfx_project/_site/
api/
obj/docfx/

# ---- Temp / scratch -------------------------------------------------------
scratch/
tmp/
temp/
*.bak
*.swp
*.orig
*.rej
*.old

# ---- Tooling --------------------------------------------------------------
.tools/
.dotnet/
.nuke/temp/
global.json.user

# ---- Claude Code / AI assistants ------------------------------------------
.claude/
CLAUDE.local.md
